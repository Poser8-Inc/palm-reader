{
  "expo": {
    "name": "Palm Reader",
    "slug": "palm-reader",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.poser8.palmreader",
      "supportsTablet": false
    },
    "android": {
      "package": "com.poser8.palmreader",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0B0F"
      }
    },
    "plugins": [
      "expo-router",
      "expo-camera"
    ],
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0B0F"
    },
    "scheme": "palmreader"
  }
}